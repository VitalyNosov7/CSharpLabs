<Window x:Class="WPFScrutiniLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFScrutiniLab"
        mc:Ignorable="d"
        Title="CalcBooking"  Width="800" Height="600" WindowState="Normal">

    <Window.Resources>

    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="5">
        <Grid Name="GridTop1" DockPanel.Dock="Top" Background="Tan" Width="Auto" Height="30"/>
        <Grid Name="GridTop2" DockPanel.Dock="Top" Background="AliceBlue" Width="Auto" Height="50"/>
        <Grid Name="GridBottom" DockPanel.Dock="Bottom" Background="BlanchedAlmond" Width="Auto" Height="30"/>
        <Grid Name="GridLeft" DockPanel.Dock="Left" Background="Aquamarine" Width="100" Height="Auto">
            <Button Content="Add" HorizontalAlignment="Left" Margin="10,9,0,0" VerticalAlignment="Top" Height="27" Width="74" Click="AddTabItem"/>
            <Button Content="Del" HorizontalAlignment="Left" Margin="15,61,0,0" VerticalAlignment="Top" Height="34" Width="64" Click="DelTabItem"/>
        </Grid>
        <Grid Name="GridCenter" Background="LightGreen">
            <TabControl x:Name="tabControl">
                <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Height="10" Width="10" Fill="Black" />
                        <TextBlock Margin="3">Стартовый  таб</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                    <DockPanel Margin="5" LastChildFill="True">
                        <Grid DockPanel.Dock="Left" Background="Aquamarine" Width="100" Height="Auto">
                            <StackPanel  Orientation="Horizontal">

                            </StackPanel>
                        </Grid>
                       
                        
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
